# Visson Pro Backend Configuration
# 复制此文件为 .env 并修改配置

# 应用名称
APP_NAME=Visson Pro

# JWT 密钥（重要：生产环境务必修改为随机字符串！）
# 生成随机字符串的方法：
# Python: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 或使用在线工具：https://randomkeygen.com/
JWT_SECRET=your-super-secret-key-change-this-in-production

# Token 过期时间（分钟）
# 0 = 永不过期（推荐用于内网/可信环境）
# 10080 = 7 天
# 1440 = 1 天
JWT_EXPIRE_MINUTES=0

# 数据库配置（一般不需要修改，使用代码中的默认值即可）
# DATABASE_URL=sqlite:///./data/visson.db

# Qwen 大模型配置（可选）
# 用于文本智能补全功能
# QWEN_API_URL=http://localhost:8000/v1/completions
# 或使用阿里云 DashScope：https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation
